#!/bin/bash

if wlr-randr | grep -q "H27T27"; then
  wlr-randr --output DP-2 --mode 2560x1440@100
fi

/home/jamie/.local/bin/set-rand-wallpaper &

foot rbw unlock

sudo pacman -S --needed --noconfirm - < /home/jamie/.local/src/dotfiles/packages/pacman.txt

sudo pacman -Syu --noconfirm
notify-send "System Update" "Done" || \
notify-send -u critical "System Update" "Failed"

ORPHANS=$(pacman -Qtdq --noconfirm)
if [ -z "$ORPHANS" ]; then
  notify-send "System Cleanup" "Nothing to remove"
else
  sudo pacman -Rns $ORPHANS --noconfirm && \
  notify-send "System Cleanup" "Done" || \
  notify-send -u critical "System Cleanup" "Failed"
fi
