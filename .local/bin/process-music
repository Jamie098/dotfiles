#!/bin/bash

COMPLETED_DIR="/mnt/drive/music/downloads/completed"
CLEAN_DIR="/mnt/drive/music/clean"
QUARANTINE_DIR="/mnt/drive/music/quarantine"
LOG_DIR="/mnt/drive/music/logs"
STAGING_DIR="/mnt/drive/music/staging"

# Create directories if they don't exist
mkdir -p "$STAGING_DIR" "$CLEAN_DIR" "$LOG_DIR" "$QUARANTINE_DIR"

# Check if there are files to process
if [ ! "$(ls -A $COMPLETED_DIR 2>/dev/null)" ]; then
    notify-send "process-music" "No new downloads to process."
    exit 0
fi

notify-send "process-music" "=== Processing music downloads $(date) ==="

# Step 1: Scan for malware
SCAN_LOG="$LOG_DIR/scan-$(date +%Y%m%d-%H%M%S).log"
notify-send "process-music" "🔍 Scanning for malware..."
clamscan -r --move="$QUARANTINE_DIR" --log="$SCAN_LOG" "$COMPLETED_DIR"

# Report quarantined files
if [ "$(ls -A $QUARANTINE_DIR 2>/dev/null)" ]; then
    notify-send "process-music" "⚠️  WARNING: Infected files moved to quarantine!"
    ls -la "$QUARANTINE_DIR"
fi

# Step 2: Move clean files to staging
notify-send "process-music" "📁 Moving clean files to staging area..."
if [ "$(ls -A $COMPLETED_DIR 2>/dev/null)" ]; then
    mv "$COMPLETED_DIR"/* "$STAGING_DIR"/
    notify-send "process-music" "✅ Files moved to staging: $STAGING_DIR"
else
    notify-send "process-music" "❌ No clean files to process (all may have been quarantined)"
    exit 1
fi
