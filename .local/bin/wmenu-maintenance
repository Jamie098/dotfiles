#!/bin/sh

choice=$(echo -e "Restow Dotfiles\nRebuild DWL\nRebuild Somebar\nRebuild Someblocks" | wmenu -l 4 -p "Run:")

case "$choice" in
  "Restow Dotfiles")
    notify-send "Restow" "Starting..."
    cd ~/.local/src/dotfiles && stow --target="$HOME" -D . && stow --target="$HOME" . && \
    notify-send "Restow" "Done" || \
    notify-send -u critical "Restow" "Failed"
    ;;

  "Rebuild DWL")
    notify-send "Rebuild DWL" "Starting..."
    cd ~/.local/src/dwl && sudo make clean install && \
    notify-send "Rebuild DWL" "Done" || \
    notify-send -u critical "Rebuild DWL" "Failed"
    ;;

  "Rebuild Somebar")
    notify-send "Rebuild Somebar" "Starting..."
    cd ~/.local/src/somebar && \
      cp src/config.def.hpp src/config.hpp && \
      meson setup build && \
      ninja -C build && \
      sudo ninja -C build install && \
    notify-send "Rebuild Somebar" "Done" || \
    notify-send -u critical "Rebuild Somebar" "Failed"
    ;;

  "Rebuild Someblocks")
    notify-send "Rebuild Someblocks" "Starting..."
    cd ~/.local/src/someblocks && sudo make clean install && \
    notify-send "Rebuild Someblocks" "Done" || \
    notify-send -u critical "Rebuild Someblocks" "Failed"
    ;;
esac
