#!/bin/bash

choice=$(echo -e "Qute\nfff\nNicotine\nPicard\nCalibre" | wmenu -l 4 -p "Start:")

case "$choice" in
  "Qute")
    qutebrowser
    ;;
  "fff")
    fff 
    ;;
  "Nicotine")
    firejail --noprofile --whitelist=/mnt/drive/music --noroot --seccomp nicotine
    ;;
  "Picard")
    picard 
    ;;
  "Calibre")
    calibre
    ;;
esac
