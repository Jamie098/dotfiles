#!/bin/bash

apps=('qutebrowser' 'fff' 'proton-pass' 'nicotine' 'calibre')
installed=()

for app in "${apps[@]}"; do
  if pacman -Q "$app" &>/dev/null; then
    installed+=("$app")
  fi
done

choice=$(printf '%s\n' "${installed[@]}" | wmenu -l "${#installed[@]}" -p "Run")

if [ "$choice" == "fff" ]; then
  foot fff
  exit 0
fi

if [ "$choice" == "nicotine" ]; then
  firejail --noprofile --whitelist=/mnt/drive/music --noroot --seccomp nicotine
  exit 0
fi

$choice
