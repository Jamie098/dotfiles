#!/bin/bash

apps=('qutebrowser' 'ferrosonic' 'alsamixer')
installed=()
declare -A needs_term

for app in "${apps[@]}"; do
  if pacman -Q "$app" &>/dev/null; then
    installed+=("$app")
  elif which "$app" &>/dev/null; then
    installed+=("$app")
    needs_term["$app"]=1
  fi
done

choice=$(printf '%s\n' "${installed[@]}" | wmenu -l "${#installed[@]}" -p "Run")

if [[ ${needs_term[$choice]} == 1 ]]; then
  foot -e "$choice" 
  exit 0
fi

$choice
