{
    "layer": "top",
    "position": "top",
    "modules-left": ["dwl/tags"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "battery"],
    "clock": {
        "format": "{:%H:%M}"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "memory": {
      "format": "≤░Ξδ {used}"
    }
}
